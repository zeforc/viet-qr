{
  "name": "@viet-qr/templates",
  "version": "1.1.0",
  "license": "MIT",
  "author": "Zeforc",
  "keywords": [
    "vietqr",
    "viet-qr",
    "viet-qr-templates",
    "templates",
    "react-vietqr"
  ],
  "description": "Premium UI templates for VietQR",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeforc/viet-qr.git"
  },
  "bugs": {
    "url": "https://github.com/zeforc/viet-qr/issues"
  },
  "homepage": "https://github.com/zeforc/viet-qr#readme",
  "exports": {
    "./styles.css": "./dist/styles.css",
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.mjs",
      "require": "./dist/vue/index.umd.js"
    },
    "./svelte": {
      "svelte": "./src/svelte/index.ts",
      "default": "./src/svelte/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && vite build",
    "dev": "tsup --watch & vite build --watch"
  },
  "peerDependencies": {
    "@viet-qr/react": "workspace:^",
    "@viet-qr/svelte": "workspace:^",
    "@viet-qr/vue": "workspace:^",
    "react": ">=18.0.0",
    "svelte": "^4.0.0 || ^5.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@viet-qr/react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "@viet-qr/vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@viet-qr/svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@viet-qr/core": "workspace:^",
    "@viet-qr/react": "workspace:^",
    "@vitejs/plugin-vue": "^5.1.0",
    "react": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^5.3.4",
    "vite-plugin-dts": "^4.0.0",
    "vue": "^3.4.31"
  }
}
