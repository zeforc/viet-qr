{
  "name": "@viet-qr/templates",
  "version": "1.3.1",
  "license": "MIT",
  "author": "Zeforc",
  "keywords": [
    "vietqr",
    "viet-qr",
    "viet-qr-react",
    "viet-qr-vue",
    "viet-qr-svelte",
    "viet-qr-templates",
    "viet-qr-payment",
    "templates",
    "qr-code"
  ],
  "description": "Premium UI templates for VietQR",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeforc/viet-qr.git"
  },
  "bugs": {
    "url": "https://github.com/zeforc/viet-qr/issues"
  },
  "homepage": "https://github.com/zeforc/viet-qr#readme",
  "files": [
    "dist",
    "src/svelte"
  ],
  "exports": {
    "./styles.css": "./dist/styles.css",
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.mjs",
      "require": "./dist/vue/index.umd.js"
    },
    "./svelte": {
      "svelte": "./src/svelte/index.ts",
      "default": "./src/svelte/index.ts"
    },
    "./elements": {
      "types": "./dist/elements/index.d.ts",
      "import": "./dist/elements/index.mjs",
      "require": "./dist/elements/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && vite build && rm -rf dist/vue/elements dist/vue/react dist/vue/svelte dist/vue/vue",
    "dev": "tsup --watch & vite build --watch"
  },
  "peerDependencies": {
    "@viet-qr/react": "workspace:^",
    "@viet-qr/svelte": "workspace:^",
    "@viet-qr/vue": "workspace:^",
    "react": ">=18.0.0",
    "svelte": "^4.0.0 || ^5.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@viet-qr/react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "@viet-qr/vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@viet-qr/svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@viet-qr/react": "workspace:^",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^6.0.3",
    "react": "^19.2.7",
    "vue": "^3.4.31",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3"
  },
  "dependencies": {
    "@viet-qr/core": "workspace:^",
    "qrcode": "^1.5.4"
  }
}
